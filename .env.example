# Copie este arquivo como .env e preencha os valores reais
# NUNCA commitar o .env real

NODE_ENV=production
PORT=3000

JWT_SECRET=gerar-com-openssl-rand-base64-48
ADMIN_PASSWORD=trocar
SUPER_PASSWORD=trocar
PI_PASSWORD=trocar
SUPER_OTP_EMAIL=email-para-receber-otp@exemplo.com

# ── Banco de dados ───────────────────────────────────────────────────────────
# Supabase (PostgreSQL) — preencha DATABASE_URL para usar Supabase.
# Deixe vazio para continuar usando SQLite local.
# Exemplo: postgresql://usuario:senha@host:5432/postgres
DATABASE_URL=

# SQLite local (usado apenas se DATABASE_URL não estiver definida)
DB_PATH=/data/campusflow.db
EVAL_DB_PATH=/data/grading.db
 
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@eusford.com
SMTP_PASS=trocar
EMAIL_FROM=PILHA <no-reply@eusford.com>

APP_BASE_URL=https://pilha.eusford.com
APP_URL=https://pilha.eusford.com

# ── Integração GitHub (GitHub App) ──────────────────────────────────
# Crie um GitHub App e preencha os valores abaixo.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=
GITHUB_CALLBACK_URL=
